{
  "_sdk_note": "Download the official ShoppingFeed OpenAPI spec from https://merchant-api-doc.shopping-feed.com/ and replace this file. The coding agent uses this file to diff API changes and update aggregators/shopping_feed/mappers.py accordingly.",
  "_spec_url": "https://api.shopping-feed.com/v1/openapi.json",
  "_auth": "Bearer token in Authorization header",
  "_key_endpoints": {
    "orders_list": "GET /v1/store/{storeId}/order",
    "order_by_reference": "GET /v1/store/{storeId}/order?reference={orderId}",
    "me": "GET /v1/me"
  },
  "_known_fields_used_in_mappers": {
    "order": [
      "id",
      "reference",
      "channelId",
      "status",
      "createdAt",
      "updatedAt",
      "payment.totalAmount",
      "payment.shippingAmount",
      "payment.currency",
      "payment.method",
      "billingAddress.firstName",
      "billingAddress.lastName",
      "billingAddress.street",
      "billingAddress.postalCode",
      "billingAddress.city",
      "billingAddress.country",
      "billingAddress.phone",
      "billingAddress.mobilePhone",
      "billingAddress.email",
      "shippingAddress.firstName",
      "shippingAddress.lastName",
      "shippingAddress.street",
      "shippingAddress.postalCode",
      "shippingAddress.city",
      "shippingAddress.country",
      "items[].reference",
      "items[].name",
      "items[].price",
      "items[].quantity"
    ]
  }
}
